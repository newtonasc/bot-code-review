# Configuração do Code Review Bot
# Preencha com suas credenciais

# ===== Configuração do Bitbucket (Obrigatório) =====

# Repository Access Token do Bitbucket OU Atlassian API Token (obrigatório)
# Opção 1 - Repository Access Token:
#   Gere em: https://bitbucket.org/{workspace}/{repo}/admin/access-tokens/
#   Permissões: Pull requests (Read, Write)
# Opção 2 - Atlassian API Token (requer BITBUCKET_USERNAME):
#   Gere em: https://id.atlassian.com/manage-profile/security/api-tokens
#   Tokens começam com "ATATT..."
BITBUCKET_TOKEN=

# Email do usuário Atlassian (obrigatório apenas para Atlassian API Tokens)
# Deixe em branco se usar Repository Access Token
BITBUCKET_USERNAME=

# Account ID do usuário Bitbucket (UUID fixo, não muda)
# Usado como fallback para detecção de reviews anteriores quando o token não
# tem permissão para GET /user (403). Recomendado para tokens de repositório.
# Obtenha com: curl -u "seu-email:seu-token" https://api.bitbucket.org/2.0/user | jq '.account_id'
BITBUCKET_ACCOUNT_ID=

# Workspace do repositório (obrigatório)
# Encontre em: https://bitbucket.org/{workspace}/
BITBUCKET_WORKSPACE=

# Slug do repositório (opcional, padrão: nome do repositório)
BITBUCKET_REPO_SLUG=

# ===== Configuração do Jira (Opcional, mas recomendado) =====

# Cloud ID do Jira (opcional, para MCP da Atlassian)
# Obtenha em: https://{seu-site}.atlassian.net/_edge/tenant_info
JIRA_CLOUD_ID=

# URL do site Jira (opcional, para links das issues nos reviews)
# Ex: your-org.atlassian.net ou https://your-org.atlassian.net
JIRA_SITE_URL=

# Chave do projeto no Jira (opcional, ex: PROJ)
# Permite detectar issues do projeto
JIRA_PROJECT_KEY=

# Atlassian API Token para acesso ao Jira (opcional, mas recomendado)
# Se não configurado, usará o BITBUCKET_TOKEN (que pode não ter acesso ao Jira)
# Gere em: https://id.atlassian.com/manage-profile/security/api-tokens
# Use o mesmo email do BITBUCKET_USERNAME
JIRA_TOKEN=

# ===== Configuração de IA (Opcional, mas recomendado para análise avançada) =====

# Provider de IA: 'claude', 'openai' ou 'github-models' (opcional)
# Habilita análise inteligente com LLMs
# - claude: Claude 3.5 Sonnet da Anthropic
# - openai: GPT-4o da OpenAI
# - github-models: Modelos do GitHub (usa infraestrutura Azure)
AI_PROVIDER=claude

# API Key do provider de IA (opcional)
# Claude: Obtenha em https://console.anthropic.com/
# OpenAI: Obtenha em https://platform.openai.com/api-keys
# GitHub Models: Obtenha em https://github.com/settings/tokens (Personal Access Token com acesso a Models)
# Deixe vazio para desabilitar análise com IA
AI_API_KEY=

# ===== Automação de Review (Opcional) =====
# Requer AI_PROVIDER configurado — as decisões são baseadas na análise da IA

# Habilita aprovação automática da PR quando o nível de risco avaliado pela IA
# estiver dentro do limite definido em AUTO_APPROVE_MAX_RISK
# Valores: true | false (padrão: false)
AUTO_APPROVE_ENABLED=false

# Nível máximo de risco aceito para aprovação automática
# Valores: low | medium | high (padrão: low)
# Exemplo: "medium" aprova automaticamente PRs com risco "low" ou "medium"
AUTO_APPROVE_MAX_RISK=low

# Habilita request changes automático quando a IA recomendar REQUEST_CHANGES
# Publica todos os comentários da análise sem interação manual
# Valores: true | false (padrão: false)
AUTO_REQUEST_CHANGES_ENABLED=false
